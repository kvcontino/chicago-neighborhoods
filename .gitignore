# --- Derived data (regenerable from scripts) ---
# Raw downloads from CDP, Census, Zillow, OSM, CTA — all reproducible
data/raw/

# Processed intermediates — every file in here is built by scripts/0X-09.
# Glob (not directory) so the !exception below works — git won't traverse
# an ignored directory even with a re-include rule.
data/processed/*

# EXCEPT typology.yaml — this is hand-authored source content, not derived.
# (typology.gpkg is derived from it by script 09 and stays ignored.)
!data/processed/typology.yaml

# Print artifacts — regenerated by scripts 10 and 11
output/*.qgz
output/*.pdf
output/*.png

# Keep the canonical ranked CSV in git (small, human-readable, useful diff)
!output/ranked_shortlist.csv

# --- Python ---
__pycache__/
*.pyc
*.pyo
.pytest_cache/

# --- QGIS scratch ---
*.qgz~
*.qgs~
*.qgs.bak

# --- Editor / OS noise ---
.DS_Store
.vscode/
.idea/
*.swp
*~

# --- Sensitive ---
# Census API key lives at ~/.census_api_key (outside the repo), but block any
# local copy just in case
.census_api_key
*.env
*.credentials.json
